# Public site URL (used for metadataBase, sitemap, og:url)
NEXT_PUBLIC_SITE_URL=https://mauro-ricardo.de

# Plausible Analytics (optional, cookieless)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mauro-ricardo.de

# Resend (for contact form email delivery)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# CONTACT_EMAIL_TO=info@mauro-ricardo.de

# Google Places API — live sync of the 3 most recent reviews + rating
# Both vars must be set; without them the reviews section falls back
# to the static snapshot baked into src/lib/reviews.ts.
# Get a key: https://console.cloud.google.com/google/maps-apis/credentials
# Find the Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_PLACE_ID=
